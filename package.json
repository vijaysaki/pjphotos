{
  "name": "pjphotos",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "node -e \"const fs=require('fs');const p=require('path');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync('dist',{recursive:true});for(const f of ['index.html','404.html','config.js','script.js','styles.css']){if(fs.existsSync(f)){fs.cpSync(f,p.join('dist',f),{recursive:true});}}\""
  }
}
